# NOTE: Secret injection is mandatory: store real credentials only in Ansible Vault or environment variables before running playbooks.
# Example: export ANSIBLE_PASSWORD_NG_SOC and reference it as ansible_password="{{ lookup('env', 'ANSIBLE_PASSWORD_NG_SOC') }}"
# Required role secrets (must not be empty or "changeme"). Use Vault or lookup('env', ...):
#   cti_ss_taxii_siem_password: "{{ lookup('env', 'CTI_SS_TAXII_SIEM_PASSWORD') }}"
#   cti_ss_taxii_telemetry_password: "{{ lookup('env', 'CTI_SS_TAXII_TELEMETRY_PASSWORD') }}"
#   ng_siem_pipeline:
#     sources:
#       - name: cti_taxii
#         password: "{{ lookup('env', 'NG_SIEM_TAXII_PASSWORD') }}"
#   ng_soar_integrations:
#     - name: siem_ingest
#       token: "{{ lookup('env', 'NG_SOAR_SIEM_INGEST_TOKEN') }}"
#   telemetry_feeder_agent:
#     outputs:
#       - type: taxii
#         password: "{{ lookup('env', 'TELEMETRY_FEEDER_TAXII_PASSWORD') }}"
#   cicms_registry:  # obligatorio si defines cicms_registry.username
#     password: "{{ lookup('env', 'CICMS_DOCKER_PASSWORD') }}"

[ng-soc]
ng-soc ansible_host=10.30.10.10 ansible_user=ubuntu ansible_password="{{ lookup('env', 'ANSIBLE_PASSWORD_NG_SOC') }}"

[ng-siem]
ng-siem ansible_host=10.30.10.20 ansible_user=ubuntu ansible_password="{{ lookup('env', 'ANSIBLE_PASSWORD_NG_SIEM') }}"

[ng-soar]
ng-soar ansible_host=10.30.20.10 ansible_user=ubuntu ansible_password="{{ lookup('env', 'ANSIBLE_PASSWORD_NG_SOAR') }}"

[cti-ss]
cti-ss ansible_host=10.30.30.10 ansible_user=ubuntu ansible_password="{{ lookup('env', 'ANSIBLE_PASSWORD_CTI_SS') }}"

[cicms-operator]
cicms-operator ansible_host=10.30.40.10 ansible_user=ubuntu ansible_password="{{ lookup('env', 'ANSIBLE_PASSWORD_CICMS') }}"

[playbook-library]
playbook-library ansible_host=10.30.30.20 ansible_user=ubuntu ansible_password="{{ lookup('env', 'ANSIBLE_PASSWORD_LIBRARY') }}"

[telemetry-feeder]
telemetry-feeder ansible_host=10.30.50.10 ansible_user=ubuntu ansible_password="{{ lookup('env', 'ANSIBLE_PASSWORD_TELEMETRY') }}"
